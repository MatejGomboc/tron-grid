# http://editorconfig.org

# top-most EditorConfig file
root = true

# default settings:
[*]
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 170

# Markdown files need trailing whitespace for line breaks
[*.md]
trim_trailing_whitespace = false
